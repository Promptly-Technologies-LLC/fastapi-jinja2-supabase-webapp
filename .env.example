# Secret key for JWT (app-level auth, not Supabase JWT)
SECRET_KEY=

# Base URL
BASE_URL=http://localhost:8000

# Database connection mode (0 = direct, 1 = pooled)
USE_POOL=0

# Shared database settings
DB_HOST=127.0.0.1
DB_SSLMODE=prefer

# Direct connection settings (when USE_POOL=0)
# When using `supabase start`, the default port is 54322 and database is "postgres".
DB_USER=postgres
DB_PASSWORD=postgres
DB_PORT=54322
DB_NAME=postgres

# Pooled connection settings (when USE_POOL=1)
# Supabase local dev pooler runs on port 54329 by default (Supavisor).
# DB_APPUSER=
# DB_APPUSER_PASSWORD=
# DB_POOL_PORT=54329
# DB_POOL_NAME=postgres

# Domain for production (used by Caddy for TLS)
DOMAIN=

# Resend
RESEND_API_KEY=
EMAIL_FROM=

############
# Supabase (self-hosted production only — not needed for local dev via `supabase start`)
############

# Supabase JWT secret (used by Supabase services for inter-service auth)
# Generate with: openssl rand -base64 32
# SUPABASE_JWT_SECRET=

# Supabase anon key (HS256-signed JWT with role=anon)
# SUPABASE_ANON_KEY=

# Supabase service role key (HS256-signed JWT with role=service_role)
# SUPABASE_SERVICE_ROLE_KEY=
